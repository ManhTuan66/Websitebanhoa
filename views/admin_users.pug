extends layout_admin

block content
  style.
    .text-gold { color: #d4af37 !important; }
    .text-small { font-size: 10px; }
    .admin-table { width: 100%; border-collapse: separate; border-spacing: 0 10px; }
    .admin-table th { color: #888; text-transform: uppercase; font-size: 0.7rem; letter-spacing: 1.5px; padding: 15px; }
    .admin-table td { background: white; padding: 15px; border-top: 1px solid #eee; border-bottom: 1px solid #eee; }
    .admin-table td:first-child { border-left: 1px solid #eee; border-radius: 10px 0 0 10px; }
    .admin-table td:last-child { border-right: 1px solid #eee; border-radius: 0 10px 10px 0; }
    .rank-badge { padding: 4px 12px; border-radius: 50px; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; }
    .rank-vip { background: #fffcf5; color: #d4af37; border: 1px solid #d4af37; }
    .rank-normal { background: #f9f9f9; color: #888; }
    .action-btn { transition: 0.3s; color: #888; font-size: 1.1rem; }
    .action-btn:hover { color: #d4af37; }
    .modal-content { background: white; padding: 30px; border-radius: 12px; width: 400px; }
    .btn-submit { background: #d4af37; color: black; border: none; padding: 12px; border-radius: 8px; font-weight: 700; width: 100%; cursor: pointer; }

  //- Modal Thêm Admin
  .modal-overlay#modalAdd(style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.5); justify-content:center; align-items:center; z-index:1000;")
    .modal-content
      h3(class="pn-font italic mb-6") Thêm quản trị viên mới
      form(action="/admin/users/add" method="POST")
        .form-group.mb-4
          label(class="text-xs font-bold uppercase") Tên đăng nhập (Username)
          input(type="text" name="username" required style="width:100%; border:1px solid #ddd; padding:10px; border-radius:8px;")
        .form-group.mb-4
          label(class="text-xs font-bold uppercase") Họ và tên
          input(type="text" name="fullName" required style="width:100%; border:1px solid #ddd; padding:10px; border-radius:8px;")
        .form-group.mb-6
          label(class="text-xs font-bold uppercase") Mật khẩu
          input(type="password" name="password" required style="width:100%; border:1px solid #ddd; padding:10px; border-radius:8px;")
        button.btn-submit(type="submit") Xác nhận thêm

  header.flex.justify-between.items-center.mb-10
    div
      h2(class="text-3xl font-bold pn-font italic") Quản lý người dùng
      p.text-gray-500 Quản lý đội ngũ admin và tài khoản khách hàng
    button(onclick="toggleForm()" style="background:#1a1a1a; color:white; padding:12px 24px; border-radius:8px; font-weight:bold; cursor:pointer;" onmouseover="this.style.background='#d4af37'; this.style.color='black'" onmouseout="this.style.background='#1a1a1a'; this.style.color='white'") 
      i.fas.fa-plus-circle.mr-2
      | Thêm Admin mới

  h3(class="text-lg font-bold pn-font italic text-gold mb-4 border-b border-[#d4af37] inline-block") Đội ngũ quản trị
  table.admin-table.mb-10
    thead
      tr.text-left
        th Tên đăng nhập
        th Họ và tên
        th Trạng thái
        th.text-center Thao tác
    tbody
      each user in users.filter(u => u.role === 'admin')
        tr
          td.font-bold @#{user.username}
          td #{user.fullName}
          td: span.text-gold.font-bold 
            i.fas.fa-circle.mr-1.text-small
            | Đang online
          td.text-center
            a(href=`/admin/users/detail/${user._id}`, class="action-btn mr-4"): i.fas.fa-eye
            a(href=`/admin/users/delete/${user._id}`, onclick="return confirm('Bạn có chắc muốn xóa Admin này?')", class="action-btn hover:text-red-500"): i.fas.fa-trash-alt

  h3(class="text-lg font-bold pn-font italic text-gold mb-4 border-b border-[#d4af37] inline-block") Khách hàng
  table.admin-table
    thead
      tr.text-left
        th Khách hàng
        th Hạng thành viên
        th Điểm tích lũy
        th.text-center Thao tác
    tbody
      each user in users.filter(u => u.role !== 'admin')
        tr
          td
            div.font-bold= user.fullName || user.username
            small.text-gray-400 ID: #{user._id.toString().slice(-6)}
          td
            if user.points >= 100
              span.rank-badge.rank-vip VIP
            else
              span.rank-badge.rank-normal Thành viên
          td.font-bold #{user.points || 0} pts
          td.text-center
            a(href=`/admin/users/detail/${user._id}`, class="action-btn mr-4"): i.fas.fa-eye
            a(href=`/admin/users/delete/${user._id}`, onclick="return confirm('Bạn có chắc muốn xóa người dùng này?')", class="action-btn hover:text-red-500"): i.fas.fa-trash-alt

  script.
    function toggleForm() {
      const modal = document.getElementById('modalAdd');
      modal.style.display = (modal.style.display === 'flex') ? 'none' : 'flex';
    }