mixin productCard(item)
  //- Thêm viền border dày hơn 1 chút: border: 1px solid #e0e0e0
  div(style="flex: 0 0 32%; background: white; border-radius: 20px; overflow: hidden; box-shadow: 0 10px 20px rgba(0,0,0,0.05); transition: 0.4s; border: 1px solid #e0e0e0; display: flex; flex-direction: column; cursor: pointer;" 
    onmouseover="this.style.transform='translateY(-10px)'; this.style.boxShadow='0 20px 40px rgba(0,0,0,0.1)'; this.style.borderColor='#d4af37';" 
    onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='0 10px 20px rgba(0,0,0,0.05)'; this.style.borderColor='#e0e0e0';"
  )
    
    // Ảnh sản phẩm
    div(style="position: relative; height: 300px;")
      img.p-img(src=(item.image || 'https://via.placeholder.com/400x500') style="width: 100%; height: 100%; object-fit: cover;")
      
      // Badge Tồn kho với hiệu ứng nhấp nháy (class="stock-badge")
      div(class="stock-badge" style="position: absolute; top: 15px; left: 15px; background: rgba(255,255,255,0.95); padding: 6px 14px; border-radius: 5px; font-size: 0.7rem; font-weight: 800; color: #1a1a1a; border: 1px solid #d4af37; box-shadow: 0 4px 6px rgba(0,0,0,0.05);")
        if item.stock > 0
          span(style="color: #27ae60; margin-right: 5px;") ● 
          | Còn #{item.stock}
        else
          span(style="color: #e74c3c; margin-right: 5px;") ● 
          | Hết hàng

    // Nội dung thẻ
    div(style="padding: 25px; text-align: center; display: flex; flex-direction: column; flex-grow: 1;")
      h3(style="font-family: 'Playfair Display', serif; font-size: 1.3rem; color: #1a1a1a; margin-bottom: 10px; line-height: 1.3; font-style: italic; min-height: 3.9rem; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;")= item.name
      
      div(style="width: 40px; height: 2px; background: #d4af37; margin: 0 auto 20px auto;")
      
      p(style="color: #555; font-weight: 700; font-size: 1.2rem; margin-bottom: 25px; margin-top: auto;")= (item.price ? item.price.toLocaleString('vi-VN') + ' đ' : 'Liên hệ')
      
      // Nút Thao tác
      div(style="display: flex; gap: 10px; justify-content: center; margin-top: auto;")
        a(href=`/flower/${item._id}` style="padding: 12px 20px; border: 1px solid #333; color: #333; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 1px; text-decoration: none; font-weight: 600; border-radius: 8px; transition: 0.3s;" onmouseover="this.style.background='#333'; this.style.color='white';" onmouseout="this.style.background='transparent'; this.style.color='#333';") Chi tiết
        
        form(action="/cart/add", method="POST" style="margin: 0;")
          input(type="hidden", name="flowerId", value=item._id.toString())
          button(
            type=(item.stock > 0 ? "submit" : "button"), 
            disabled=(item.stock <= 0),
            style=`padding: 12px 20px; border: none; background: ${item.stock > 0 ? '#d4af37' : '#eee'}; color: ${item.stock > 0 ? 'white' : '#999'}; cursor: ${item.stock > 0 ? 'pointer' : 'not-allowed'}; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; font-weight: 600; border-radius: 8px; transition: 0.3s;`
          )
            | Thêm vào giỏ

mixin sectionDivider
  div(style="text-align: center; margin: 60px 0; color: #d4af37; display: flex; align-items: center; justify-content: center; gap: 20px;")
    div(style="height: 1px; width: 100px; background: #d4af37;")
    div(style="font-size: 1.5rem;") ❦
    div(style="height: 1px; width: 100px; background: #d4af37;")