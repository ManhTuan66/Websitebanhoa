extends layout
include mixins

block content
  link(href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Lora:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet")
  
  style.
    .wiki-container { max-width: 900px; margin: 0 auto; padding: 40px 20px; font-family: 'Lora', serif; color: #202122; }
    /* Dictionary Header style */
    .dict-header { font-family: 'Inter', sans-serif; text-transform: uppercase; letter-spacing: 0.3rem; font-size: 0.7rem; color: #a2a9b1; margin-bottom: 20px; text-align: center; border-bottom: 1px solid #eee; padding-bottom: 10px; }
    .wiki-title { font-size: 2.5rem; font-weight: 400; border-bottom: 1px solid #a2a9b1; padding-bottom: 0.25em; margin-bottom: 0.5em; }
    .infobox { float: right; width: 300px; background: #f8f9fa; border: 1px solid #a2a9b1; padding: 15px; margin: 0 0 10px 20px; font-family: 'Inter', sans-serif; font-size: 0.85rem; }
    .infobox img { width: 100%; height: auto; border: 1px solid #c8ccd1; margin-bottom: 10px; }
    .section-header { font-family: 'Inter', sans-serif; font-size: 1.4rem; border-bottom: 1px solid #a2a9b1; padding-top: 30px; margin-bottom: 15px; font-weight: 600; }
    .data-row { display: flex; padding: 6px 0; border-bottom: 1px solid #eaecf0; }
    .data-label { font-weight: 600; width: 45%; color: #54595d; }
    /* Classic Back Button */
    .back-btn { display: block; width: fit-content; margin: 50px auto; padding: 10px 25px; border: 1px solid #d4af37; color: #d4af37; text-decoration: none; font-family: 'Inter', sans-serif; font-size: 0.8rem; letter-spacing: 0.1rem; transition: 0.3s; }
    .back-btn:hover { background: #d4af37; color: white; }

  .wiki-container
    //- Dictionary Header
    .dict-header Bách khoa toàn thư thực vật PNShop — Tập 2026
    
    //- Title Section
    h1.wiki-title= entry.common_name
    p(style="font-style: italic; color: #54595d; font-family: 'Lora', serif; margin-bottom: 20px;")= entry.scientific_name
    
    //- Infobox
    .infobox
      img(src=entry.image, alt=entry.common_name)
      .data-row
        .data-label Họ:
        div= entry.taxonomy.family || 'N/A'
      .data-row
        .data-label Chi:
        div= entry.taxonomy.genus || 'N/A'
      .data-row
        .data-label Bộ:
        div= entry.taxonomy.order || 'N/A'
      .data-row
        .data-label Độ pH đất:
        div= entry.ecology.soil_ph || 'N/A'
      .data-row
        .data-label Ánh sáng:
        div= entry.ecology.light || 'N/A'

    //- Content
    .wiki-content
      h2.section-header Hình thái học
      p(style="line-height: 1.7;")= entry.morphology.flower || 'Thông tin chi tiết về hoa hiện đang được cập nhật.'
      p(style="line-height: 1.7;")= entry.morphology.leaf || 'Thông tin chi tiết về lá hiện đang được cập nhật.'

      h2.section-header Sinh thái học
      p(style="line-height: 1.7;") 
        | Loài này phát triển mạnh trong điều kiện nhiệt độ khoảng 
        b= entry.ecology.temperature || 'N/A'
        | . Đặc điểm sinh trưởng hoàn toàn phù hợp với môi trường sống tự nhiên của chúng.

      h2.section-header Ý nghĩa văn hóa
      p(style="line-height: 1.7;")= entry.heritage.symbolism || 'Thông tin biểu tượng chưa có sẵn.'

    //- Back Button at bottom
    a.back-btn(href="/wiki") ← TRỞ VỀ THƯ VIỆN

    //- Footer
    footer(style="margin-top: 40px; border-top: 1px solid #a2a9b1; padding-top: 10px; font-size: 0.75rem; color: #72777d; font-family: 'Inter', sans-serif; text-align: center;")
      p Thư viện PNShop | Tài liệu tham khảo thực vật học.