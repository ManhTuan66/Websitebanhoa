doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= title + " | VNUA Flora Admin"
    link(rel="stylesheet", href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css")
    link(href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap", rel="stylesheet")
    style.
      body { 
        font-family: 'Be Vietnam Pro', sans-serif; 
        background: #FFF0F3; 
        color: #2D3436;
      }
      .import-card {
        background: #FFFFFF;
        border-radius: 30px;
        box-shadow: 0 15px 45px rgba(255, 133, 161, 0.08);
        border: 1px solid rgba(255, 133, 161, 0.1);
      }
      .form-label {
        color: #4A4A4A;
        font-weight: 600;
        font-size: 0.95rem;
      }
      .form-control, .form-select {
        border-radius: 12px;
        padding: 12px 15px;
        border: 1px solid #FBB1BD;
      }
      .form-control:focus, .form-select:focus {
        border-color: #FF85A1;
        box-shadow: 0 0 0 0.25rem rgba(255, 133, 161, 0.25);
      }
      .btn-submit {
        background: #FF85A1;
        color: white;
        font-weight: 700;
        padding: 12px 35px;
        border-radius: 50px;
        border: none;
        transition: 0.3s;
      }
      .btn-submit:hover {
        background: #E91E63;
        transform: translateY(-2px);
      }

  body
    .container.py-5
      .row.justify-content-center
        .col-lg-7
          a.text-decoration-none.d-inline-flex.align-items-center.mb-4(href="/admin" style="color: #E91E63; font-weight: 600;")
            i.fas.fa-arrow-left.me-2
            | Quay lại trang quản trị chính

          .import-card.p-4.p-md-5
            .text-center.mb-4
              div(style="width: 70px; height: 70px; background: #FFF0F3; border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; margin-bottom: 15px;")
                i.fas.fa-boxes-packing.fa-2x(style="color: #FF85A1;")
              h2.fw-bold(style="color: #E91E63;") Phiếu Nhập Kho Cửa Hàng
              p.text-muted Hệ thống tự động lưu lịch sử và cộng dồn số lượng tồn kho.

            hr.my-4(style="border-top: 2px dashed #FBB1BD; opacity: 0.5;")

            form(action="/admin/import-stock" method="POST")
              
              .mb-4
                label.form-label Chọn loài hoa cần nhập:
                select.form-select(name="productId" required)
                  option(value="" disabled selected) -- Chọn một loài hoa từ danh sách --
                  each flower in flowers
                    option(value=flower._id) #{flower.name} (Hiện tồn: #{flower.stock || 0} chậu)

              .row
                .col-md-6.mb-4
                  label.form-label Số lượng nhập thêm (chậu):
                  input.form-control(type="number" name="quantity" min="1" required placeholder="Ví dụ: 50")
                
                .col-md-6.mb-4
                  label.form-label Giá nhập gốc (đ / chậu):
                  input.form-control(type="number" name="importPrice" min="0" required placeholder="Ví dụ: 45000")

              .mb-4
                label.form-label Ghi chú nội bộ:
                textarea.form-control(name="note" rows="3" placeholder="Ví dụ: Nhập bổ sung đợt hoa từ Trâu Quỳ...")

              .d-flex.justify-content-end.gap-3.mt-4
                a.btn.btn-light(href="/admin" style="border-radius: 50px; padding: 12px 25px; font-weight: 600; color: #777;") Hủy bỏ
                button.btn-submit(type="submit")
                  i.fas.fa-check.me-2
                  | Xác nhận nhập kho