extends layout
include mixins

block content
  //- 1. HERO SECTION (Luxury Style)
  section(style="padding: 100px 8%; text-align: center; background: #fffcf5; border-bottom: 1px solid #d4af37;")
    h1(style="font-family: 'Playfair Display', serif; font-size: 3.5rem; color: #1a1a1a; font-style: italic; margin-bottom: 15px;") Góc nhìn PNShop
    p(style="font-family: 'Poppins', sans-serif; letter-spacing: 3px; color: #888; text-transform: uppercase; font-size: 0.8rem;") Nghệ thuật sống cùng hoa

  //- 2. BLOG GRID (Bố cục 3 cột)
  main(style="padding: 60px 8%; max-width: 1300px; margin: 0 auto;")
    .grid-container(style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px;")
      if posts && posts.length > 0
        each post in posts
          article(style="background: white; border: 1px solid #e0c9a6; display: flex; flex-direction: column; transition: 0.4s;")
            .blog-img-wrapper(style="width: 100%; height: 280px; overflow: hidden;")
              img(src=post.image style="width: 100%; height: 100%; object-fit: cover; transition: 0.5s;" onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'")
            
            .blog-content(style="padding: 30px; flex-grow: 1;")
              span(style="color: #d4af37; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 2px;")= post.category || 'Phong cách sống'
              h3(style="font-family: 'Playfair Display', serif; font-size: 1.4rem; margin: 15px 0; color: #1a1a1a; line-height: 1.3;")= post.title
              p(style="color: #666; font-size: 0.9rem; line-height: 1.6; margin-bottom: 25px;")= post.summary
              
              .blog-footer(style="border-top: 1px solid #f0f0f0; padding-top: 15px; display: flex; justify-content: space-between; align-items: center;")
                span(style="font-size: 0.75rem; color: #aaa;")= new Date(post.createdAt).toLocaleDateString('vi-VN')
                a(href=`/blog/${post.slug}` style="color: #1a1a1a; text-decoration: none; font-weight: 600; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1.5px;") Xem thêm

  //- 3. CLOSING SECTION (Lời chào tạm biệt)
  section(style="padding: 80px 8%; text-align: center; background: #fffcf5; border-top: 1px solid #e0c9a6;")
    div(style="max-width: 600px; margin: 0 auto;")
      div(style="font-size: 2rem; color: #d4af37; margin-bottom: 20px;")
        i.fas.fa-leaf
      
      h3(style="font-family: 'Playfair Display', serif; font-size: 1.8rem; color: #1a1a1a; margin-bottom: 20px; font-style: italic;") Cảm ơn bạn đã ghé thăm.
      
      p(style="font-family: 'Poppins', sans-serif; font-size: 0.95rem; color: #777; line-height: 1.8; letter-spacing: 0.5px;") 
        | Chúng tôi thực sự trân trọng những phút giây bạn dành để đọc những chia sẻ từ PNShop. 
        | Rất vui được đồng hành cùng bạn, hy vọng rằng những con chữ này đã mang đến chút hương sắc cho ngày của bạn.
      div(style="margin-top: 30px; font-family: 'Playfair Display', serif; font-size: 1.1rem; color: #1a1a1a; font-style: italic;")
        | Thân ái, 
        br
        | Đội ngũ PNShop