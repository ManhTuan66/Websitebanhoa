extends layout_admin

block content
  // Tích hợp thư viện Excel
  script(src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js")
  
  style.
    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Playfair+Display:ital,wght@0,700;1,700&display=swap');

    :root { --gold: #d4af37; --dark: #1a1a1a; }

    .admin-main { background-color: #fcfcfc; padding: 40px; font-family: 'Montserrat', sans-serif; }
    
    /* Typography */
    h2, h3 { font-family: 'Playfair Display', serif; color: var(--dark); font-weight: 700; font-style: italic; margin-bottom: 20px; }
    
    .admin-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid var(--gold); padding-bottom: 20px; margin-bottom: 30px; }
    
    /* Buttons */
    .btn-add { background: var(--dark); color: white; border: 1px solid var(--gold); padding: 12px 25px; border-radius: 8px; font-weight: 700; cursor: pointer; transition: 0.3s; display: flex; align-items: center; gap: 8px; text-decoration: none; }
    .btn-add:hover { background: var(--gold); color: white; border-color: var(--dark); }
    
    .btn-action { background: transparent; color: var(--gold); border: 1px solid var(--gold); padding: 5px 12px; border-radius: 6px; font-size: 0.75rem; cursor: pointer; margin-left: 8px; }
    .btn-action:hover { background: var(--gold); color: white; }

    /* Inventory Table Grouping */
    .day-group-header { display: flex; justify-content: space-between; align-items: center; padding: 15px 20px; background: #fff; border: 1px solid #eee; border-radius: 10px; border-left: 4px solid var(--gold); margin-top: 30px; }
    .day-total { font-weight: 700; color: var(--dark); margin-right: 15px; }
    .day-total span { color: var(--gold); font-weight: 800; }
    
    .admin-table { width: 100%; border-collapse: collapse; margin-bottom: 20px; background: white; }
    .admin-table th { padding: 15px; text-align: left; color: #888; font-size: 0.7rem; text-transform: uppercase; border-bottom: 2px solid #eee; }
    .admin-table td { padding: 20px 15px; border-bottom: 1px solid #f9f9f9; font-weight: 600; color: #444; }
    
    .flower-thumb { width: 40px; height: 40px; object-fit: cover; border-radius: 8px; margin-right: 10px; }
    .qty-badge { background: #fdf5e6; color: var(--gold); padding: 4px 10px; border-radius: 6px; font-size: 0.75rem; border: 1px solid var(--gold); }

    /* Modal Styling */
    .modal { display: none; position: fixed; z-index: 2000; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.6); backdrop-filter: blur(5px); align-items: center; justify-content: center; }
    .modal-content { background: white; padding: 40px; border-radius: 20px; width: 500px; border: 1px solid #eee; }
    .form-group label { font-weight: 700; font-size: 11px; color: #888; text-transform: uppercase; margin-bottom: 8px; display: block; }
    .form-group input, .form-group select, .form-group textarea { width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 10px; background: #fdfdfd; }

  main.admin-main
    header.admin-header
      h2 📦 Nhật ký kho
      button.btn-add(type="button" onclick="openImportModal()")
        i.fas.fa-plus-circle
        | Nhập kho

    if history && history.length > 0
      - var groups = {}
      each item in history
        - var dateKey = new Date(item.import_date).toLocaleDateString('vi-VN')
        if !groups[dateKey]
          - groups[dateKey] = { items: [], totalCost: 0 }
        - groups[dateKey].items.push(item)
        - groups[dateKey].totalCost += (item.quantity * item.import_price)
      
      each groupData, dateString in groups
        - var cleanDate = dateString.replace(/\//g, '-')
        .day-group-header
          div(style="cursor: pointer;" onclick=`toggleTable('${cleanDate}')`)
            h3(style="margin:0; font-size: 1.1rem;") 🗓️ Ngày: #{dateString}
          div(style="display: flex; align-items: center;")
            div.day-total Tổng chi: 
              span #{groupData.totalCost.toLocaleString('vi-VN')} đ
            button.btn-action(onclick=`exportAndCollapse('${cleanDate}')`) 
              i.fas.fa-file-excel
              | Xuất & Đóng
            button.btn-action(onclick=`toggleTable('${cleanDate}')`) 
              i.fas.fa-chevron-down
              | Thu gọn
        
        table.admin-table(id=`table-${cleanDate}`)
          thead
            tr
              th Thời gian
              th Sản phẩm
              th Số lượng
              th Đơn giá
              th Thành tiền
              th Ghi chú
          tbody
            each item in groupData.items
              tr
                td= new Date(item.import_date).toLocaleTimeString('vi-VN', {hour: '2-digit', minute:'2-digit'})
                td
                  div(style="display: flex; align-items: center;")
                    if item.flower_info
                      img.flower-thumb(src=item.flower_info.image)
                      strong(style="color: var(--dark);")= item.flower_info.name
                td: span.qty-badge +#{item.quantity}
                td #{item.import_price.toLocaleString('vi-VN')} đ
                td: strong(style="color: var(--dark);") #{(item.quantity * item.import_price).toLocaleString('vi-VN')} đ
                td(style="color: #888; font-style: italic;")= item.note || '---'
    else
      p(style="color: #888; text-align: center; padding: 50px;") Chưa có dữ liệu nhập kho.

    // Import Modal
    #importModal.modal
      .modal-content
        h3(style="margin-bottom: 25px;") Thêm sản phẩm nhập kho
        form(action="/admin/import-stock" method="POST")
          .form-group
            label Chọn sản phẩm:
            select(name="productId" required)
              option(value="" disabled selected) -- Chọn sản phẩm --
              if flowers
                each flower in flowers
                  option(value=flower._id) #{flower.name}
          .form-group
            label Số lượng:
            input(
              type="number" 
              name="quantity" 
              min="1" 
              step="1" 
              required 
              oninput="validatePositiveInteger(this)"
            )
            small(style="color: #888; font-size: 0.75rem;") Vui lòng nhập đúng định dạng là số

          .form-group
            label Giá nhập (VNĐ):
            input(
              type="number" 
              name="importPrice" 
              min="1" 
              step="1" 
              required 
              oninput="validatePositiveInteger(this)"
            )
            small(style="color: #888; font-size: 0.75rem;") Vui lòng nhập đúng định dạng là số
          .form-group
            label Ghi chú:
            textarea(name="note" rows="2")
          button.btn-add(type="submit" style="width: 100%; justify-content: center; margin-top: 10px;") Xác nhận nhập kho

  script.
    function openImportModal() { document.getElementById('importModal').style.display = 'flex'; }
    function closeImportModal() { document.getElementById('importModal').style.display = 'none'; }
    
    function toggleTable(dateId) {
      const table = document.getElementById(`table-${dateId}`);
      table.style.display = (table.style.display === "none") ? "table" : "none";
    }

    function exportAndCollapse(dateId) {
      const table = document.getElementById(`table-${dateId}`);
      const wb = XLSX.utils.table_to_book(table, { sheet: "DuLieuNhapKho" });
      XLSX.writeFile(wb, `NhapKho_${dateId}.xlsx`);
      table.style.display = "none";
    }

    window.onclick = function(event) { 
      if (event.target == document.getElementById('importModal')) closeImportModal(); 
    }

    function validatePositiveInteger(input) {
    // Loại bỏ mọi ký tự không phải số
    input.value = input.value.replace(/[^0-9]/g, '');
    // Đảm bảo không bắt đầu bằng số 0
    if (input.value.startsWith('0')) {
      input.value = input.value.replace(/^0+/, '');
    }
    // Nếu rỗng sau khi lọc, gán bằng 1
    if (input.value === '') {
      input.value = 0;
    }
    }