doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    title Đăng ký | PNShop
    link(href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css")
    script(src="https://cdn.tailwindcss.com")
    style.
      body { font-family: 'Montserrat', sans-serif; background: #fff5f7; }
      .register-box { 
        background: #ffffff; 
        border: 2px solid #e11d48; 
        box-shadow: 0 25px 50px -12px rgba(225, 29, 72, 0.15);
      }
      .rose-deep { color: #881337; }
      .leaf-green { color: #064e3b; }
      .rose-btn { 
        background: #064e3b; 
        color: white; 
        font-weight: 700; 
        transition: 0.3s; 
      }
      .rose-btn:hover { background: #065f46; }
      h1 { font-family: 'Playfair Display', serif; font-style: italic; color: #881337; }
      input, select, textarea { 
        background: #fff1f2 !important; 
        border: 1px solid #fda4af !important; 
        color: #4c0519 !important; 
      }
      input:focus, select:focus, textarea:focus { border-color: #064e3b !important; outline: none; }
      .icon-accent { color: #064e3b; }

  body(class="flex items-center justify-center min-h-screen py-10 px-4")
    div(class="register-box p-10 rounded-[3rem] w-full max-w-lg")
      h1(class="text-4xl font-extrabold mb-2 text-center") 🌹 Đăng ký tài khoản
      p(class="text-rose-400 mb-8 font-medium text-center italic") Gia nhập cộng đồng hoa tại PNShop
      
      if (error)
        div(class="bg-rose-50 text-rose-600 p-4 rounded-xl mb-6 font-medium text-sm border border-rose-200")
          i.fas.fa-exclamation-circle.mr-2
          = error

      form(action="/register", method="POST", class="space-y-5")
        div(class="grid grid-cols-2 gap-4")
          div
            label(class="block text-xs font-bold leaf-green uppercase tracking-widest mb-2") 
              i.fas.fa-user.mr-2.icon-accent
              | Tên đăng nhập
            input(type="text", name="username", required, class="w-full px-4 py-3 rounded-2xl transition")
          div
            label(class="block text-xs font-bold leaf-green uppercase tracking-widest mb-2") 
              i.fas.fa-signature.mr-2.icon-accent
              | Họ và tên
            input(type="text", name="fullName", required, class="w-full px-4 py-3 rounded-2xl transition")
        
        div
          label(class="block text-xs font-bold leaf-green uppercase tracking-widest mb-2") 
            i.fas.fa-lock.mr-2.icon-accent
            | Mật khẩu
          input(type="password", name="password", required, class="w-full px-4 py-3 rounded-2xl transition")
        
        div(class="grid grid-cols-2 gap-4")
          div
            label(class="block text-xs font-bold leaf-green uppercase tracking-widest mb-2") 
              i.fas.fa-phone.mr-2.icon-accent
              | Số điện thoại
            input(type="text", name="phone", required, class="w-full px-4 py-3 rounded-2xl transition")
          div
            label(class="block text-xs font-bold leaf-green uppercase tracking-widest mb-2") 
              i.fas.fa-user-tag.mr-2.icon-accent
              | Vai trò
            select(name="role", class="w-full px-4 py-3 rounded-2xl transition")
              option(value="customer") Khách hàng
              option(value="admin") Quản trị viên
        
        div
          label(class="block text-xs font-bold leaf-green uppercase tracking-widest mb-2") 
            i.fas.fa-map-marker-alt.mr-2.icon-accent
            | Địa chỉ
          textarea(name="address", required, class="w-full px-4 py-3 rounded-2xl transition h-20")
        
        button(type="submit", class="w-full rose-btn py-4 rounded-2xl transition shadow-lg mt-2 uppercase tracking-widest") Đăng ký ngay
        
        div(class="mt-8 pt-6 border-t border-rose-50 text-center")
          p(class="text-sm text-slate-500") Đã có tài khoản? 
            a(href="/login", class="rose-deep font-bold hover:underline") Đăng nhập