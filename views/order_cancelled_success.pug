doctype html
html(lang="vi")
  head
    title Hủy đơn hàng thành công
    link(rel="stylesheet", href="/public/style.css")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css")
    style.
      .success-container { text-align: center; padding: 100px 20px; }
      .success-icon { color: #ff7675; font-size: 80px; margin-bottom: 20px; }
      .btn-home { background: #2ecc71; color: white; padding: 10px 20px; text-decoration: none; border-radius: 5px; margin-top: 20px; display: inline-block; }

  body
    .success-container
      i.fas.fa-trash-alt.success-icon
      h1 Đã hủy đơn hàng!
      p Đơn hàng của bạn đã được hủy thành công theo yêu cầu.
      p Số lượng sản phẩm đã được hoàn trả lại vào kho hàng của chúng tôi.
      a.btn-home(href="/") <i class="fas fa-home"></i> Quay về trang chủ