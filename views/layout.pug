doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title PNShop - Thế giới hoa tươi
    // Font: Outfit (hiện đại) và Playfair Display (cho logo tinh tế)
    link(href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600&family=Playfair+Display:ital,wght@0,600;1,600&display=swap" rel="stylesheet")
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css")
    script(src="https://cdn.tailwindcss.com")
    style.
      body { font-family: 'Outfit', sans-serif; }
      .logo-font { font-family: 'Playfair Display', serif; }
      .fade-banner { transition: opacity 1s ease-in-out; }
      
  body(class="bg-rose-50/30 text-slate-800")
    
    // NAVBAR: Thiết kế đồng bộ chủ đề hoa
    nav(class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-rose-100 py-5")
      div(class="container mx-auto px-6 flex justify-between items-center")
        // Logo
        a(href="/", class="text-4xl italic text-rose-600 logo-font hover:text-rose-700 transition") PNShop
        
        /// Menu chính
        div(class="hidden md:flex space-x-12")
          - 
            const menuItems = [
              { name: 'Trang chủ', url: '/' },
              { name: 'Cửa hàng', url: '/explore' },
              { name: 'Ưu đãi', url: '/vouchers' },
              { name: 'Tin tức', url: '/blog' },
              { name: 'Kiến thức', url: '/wiki' }
            ]
          
          each item in menuItems
            a(href=item.url, 
              class="text-lg font-medium text-emerald-800 hover:text-rose-500 transition-all duration-300 relative group")
              = item.name
              span(class="absolute -bottom-1 left-0 w-0 h-0.5 bg-rose-400 transition-all duration-300 group-hover:w-full")
        
        // Nút bên phải (Giỏ hàng & User)
        div(class="flex items-center gap-6")
          // Giỏ hàng
          a(href="/cart", class="relative text-emerald-800 hover:text-rose-500 transition-all text-xl")
            i(class="fas fa-shopping-basket")
            if typeof cartCount !== 'undefined' && cartCount > 0
              span(class="absolute -top-2 -right-2 bg-rose-500 text-white text-[10px] w-5 h-5 flex items-center justify-center rounded-full font-bold")= cartCount
          
          // User Session logic
          if session && session.user
            // Khi đã đăng nhập
            if session.user.role === 'admin'
              a(href="/admin", title="Quản trị", class="text-emerald-800 hover:text-rose-500 transition-all text-xl")
                i(class="fas fa-user-shield")
            
            a(href="/profile", title="Tài khoản", class="text-emerald-800 hover:text-rose-500 transition-all text-xl")
              i(class="fas fa-user-circle")
            
            a(href="/logout", class="text-sm font-semibold text-rose-600 border border-rose-200 px-4 py-2 rounded-full hover:bg-rose-600 hover:text-white transition-all duration-300 shadow-sm") 
              | Đăng xuất
          else
            // Khi chưa đăng nhập
            a(href="/login", class="border border-emerald-600 text-emerald-800 px-6 py-2 rounded-full font-semibold hover:bg-emerald-600 hover:text-white transition shadow-sm") 
              | Đăng nhập

    // BANNER
    div(id="banner-container", class="relative w-full h-[400px] flex items-center justify-center bg-cover bg-center fade-banner")
      div(class="absolute inset-0 bg-black/20")
      div(class="relative z-10 text-center text-white px-4")
        h1(id="banner-title", class="text-6xl italic logo-font mb-3") PNShop
        p(id="banner-desc", class="text-xl font-light tracking-widest uppercase") "Thế giới hoa tươi – Trao gửi những khoảnh khắc yêu thương"

    // Nội dung trang
    main(class="container mx-auto px-6 py-16")
      block content

    // Logic Banner
    script.
      const banners = [
        { img: 'https://images.unsplash.com/photo-1518709268805-4e9042af9f23?q=80', title: 'PNShop', desc: '"Thế giới hoa tươi – Trao gửi những khoảnh khắc yêu thương"' },
        { img: 'https://images.unsplash.com/photo-1490750967868-88aa4486c946?q=80', title: 'Khoảnh khắc', desc: '"Lưu giữ những kỷ niệm ngọt ngào"' },
        { img: 'https://images.unsplash.com/photo-1562690868-60bbe7293e94?q=80', title: 'Sắc màu', desc: '"Khởi đầu ngày mới đầy tươi trẻ"' }
      ];
      let current = 0;
      const container = document.getElementById('banner-container');
      const title = document.getElementById('banner-title');
      const desc = document.getElementById('banner-desc');

      setInterval(() => {
        container.style.opacity = 0;
        setTimeout(() => {
          current = (current + 1) % banners.length;
          container.style.backgroundImage = `url('${banners[current].img}')`;
          title.innerText = banners[current].title;
          desc.innerText = banners[current].desc;
          container.style.opacity = 1;
        }, 1000);
      }, 5000);

      container.style.backgroundImage = `url('${banners[0].img}')`;
      
    // FOOTER
    footer(class="bg-slate-900 text-slate-200 pt-16 pb-8 px-6 font-['Outfit']")
      div(class="container mx-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12")
        
        // Brand Column
        div(class="space-y-4")
          a(href="/", class="text-4xl italic text-rose-500 logo-font") PNShop
          p(class="text-slate-400 leading-relaxed text-sm") "Tại PNShop, chúng tôi tuyển chọn những đóa hoa tinh tế nhất để giúp bạn gửi trao lời yêu thương đến những người trân quý."
          div(class="flex gap-4 pt-2")
            each color in [['facebook-f', 'hover:text-blue-500'], ['instagram', 'hover:text-pink-500'], ['tiktok', 'hover:text-white']]
              a(href="#", class=`w-10 h-10 flex items-center justify-center rounded-full bg-slate-800 text-slate-400 transition-all ${color[1]} hover:bg-slate-700`)
                i(class=`fab fa-${color[0]}`)
        
        // Services Column
        div
          h4(class="text-lg font-bold text-white mb-6 border-l-4 border-rose-500 pl-3 uppercase tracking-wider") Dịch vụ
          ul(class="space-y-3")
            each link in [{name: 'Trang chủ', url: '/'}, {name: 'Cửa hàng', url: '/explore'}, {name: 'Ưu đãi', url: '/vouchers'}, {name: 'Tin tức', url: '/blog'}, {name: 'Kiến thức', url: '/wiki'}]
              li: a(href=link.url, class="text-slate-400 hover:text-rose-400 hover:translate-x-2 transition-all block text-sm")= link.name
        
        // Support Column
        div
          h4(class="text-lg font-bold text-white mb-6 border-l-4 border-rose-500 pl-3 uppercase tracking-wider") Hỗ trợ
          ul(class="space-y-3")
            each link in [{name: 'Lịch sử đơn hàng', url: '/my-orders'}, {name: 'Tra cứu đơn hàng', url: '/track-order'}]
              li: a(href=link.url, class="text-slate-400 hover:text-rose-400 hover:translate-x-2 transition-all block text-sm")= link.name

        // Contact Column
        div
          h4(class="text-lg font-bold text-white mb-6 border-l-4 border-rose-500 pl-3 uppercase tracking-wider") Liên hệ
          ul(class="space-y-4 text-slate-400 text-sm")
            li(class="flex items-start gap-3")
              i(class="fas fa-map-marker-alt text-rose-500 mt-1")
              | Trâu Quỳ, Gia Lâm, Hà Nội
            li(class="flex items-center gap-3")
              i(class="fas fa-phone-alt text-rose-500")
              | 0123 456 789
            li(class="flex items-center gap-3")
              i(class="fas fa-envelope text-rose-500")
              | support@pnshop.vn

      // Copyright
      div(class="text-center pt-8 border-t border-slate-800 text-slate-500 text-xs tracking-widest uppercase")
        p &copy; 2026 PNShop. Bản quyền đã được bảo hộ. Thiết kế với ❤️ bởi đội ngũ PNShop.

    // --- NÚT CHAT BÊN GÓC ---
    div(class="fixed bottom-8 right-8 flex flex-col gap-4 z-[9999]")
      a(href="https://zalo.me/0398102869", target="_blank", class="w-14 h-14 bg-slate-800 text-blue-400 border border-slate-700 rounded-full flex items-center justify-center shadow-2xl hover:scale-110 hover:bg-white transition-all")
        i(class="fas fa-comment-dots text-2xl")
      a(href="#", target="_blank", class="w-14 h-14 bg-slate-800 text-sky-400 border border-slate-700 rounded-full flex items-center justify-center shadow-2xl hover:scale-110 hover:bg-white transition-all")
        i(class="fab fa-facebook-messenger text-2xl")