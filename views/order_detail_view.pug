extends layout

block content
  style.
    .order-detail-container { 
      padding: 60px 8%; 
      background: #fffcf5; 
      font-family: 'Quicksand', sans-serif; /* Font đọc rõ ràng, hiện đại */
    }
    .detail-card { 
      max-width: 700px; 
      margin: 0 auto; 
      background: white; 
      padding: 50px; 
      border: 1px solid #d4af37;
      box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }
    .row { 
      display: flex; 
      justify-content: space-between; 
      padding: 15px 0; 
      border-bottom: 1px solid #f2f2f2; 
      color: #333; 
    }
    h4 { 
      font-family: 'Playfair Display', serif; /* Cổ điển và sang trọng */
      color: #1a1a1a; 
      margin-top: 40px; 
      display: flex; 
      align-items: center; 
      gap: 12px; 
      font-style: italic;
      border-bottom: 1px solid #d4af37;
      padding-bottom: 10px;
      font-size: 1.4rem;
    }
    
    /* Box lời nhắn ra ngoài với style cổ điển */
    .support-outer { 
      max-width: 700px; 
      margin: 20px auto 0 auto; 
      text-align: center; 
    }
    .support-text { 
      font-family: 'Playfair Display', serif; 
      font-size: 1.1rem; 
      color: #555; 
      font-style: italic; 
      margin-bottom: 20px; 
    }
    
    .btn-back { 
      display: inline-block; 
      padding: 12px 35px; 
      background: #1a1a1a; 
      color: white; 
      text-decoration: none; 
      font-family: 'Poppins', sans-serif; 
      text-transform: uppercase; 
      font-size: 0.75rem; 
      letter-spacing: 2px;
      font-weight: 600; 
      transition: 0.3s; 
    }
    .btn-back:hover { background: #d4af37; }

  .order-detail-container
    .detail-card
      h2(style="text-align: center; font-family: 'Playfair Display'; font-style: italic; color: #1a1a1a; margin-bottom: 10px;") Order Details
      p(style="text-align:center; color:#888; font-size: 0.9rem; letter-spacing: 2px; margin-bottom: 40px;") ORDER ID: #{order._id.toString().slice(-8).toUpperCase()}
      
      h4 <i class="fas fa-user-circle" style="color: #d4af37;"></i> Sender Information
      .row: span Full Name: #[strong #{order.senderName || order.orderedBy.fullName}]
      .row: span Phone: #[strong #{order.senderPhone || 'Not provided'}]

      h4 <i class="fas fa-gift" style="color: #d4af37;"></i> Recipient Information
      .row: span Name: #[strong #{order.customer.name}]
      .row: span Phone: #[strong #{order.customer.phone}]
      .row: span Address: #[span #{order.customer.address}]
      .row: span Message: #[em(style="color: #666;") "#{order.note || 'None'}"]
      .row: span Delivery Time: #[strong #{order.customer.deliveryTime || 'As soon as possible'}]

      h4 <i class="fas fa-receipt" style="color: #d4af37;"></i> Payment Summary
      .row: span Method: #[strong #{order.paymentMethod === 'BANK' ? 'Bank Transfer' : 'Cash on Delivery (COD)'}]
      .row: span Total Amount: #[strong(style="color: #d4af37; font-size: 1.2rem;") #{order.totalAmount.toLocaleString('vi-VN')} VND]

    //- Phần lời nhắn nằm ngoài card, tạo cảm giác như một ghi chú chân trang tinh tế
    .support-outer
      p.support-text "If you need any assistance or have special requests regarding your order, please feel free to reach out to our team via the chatbox. We are always here to help."
      a.btn-back(href="/my-orders") Back to Order List