extends layout
include mixins

//- MIXIN FOR PRODUCTS (Với nút Xem và Thêm vào giỏ)
  mixin productCard(item, color)
  div(style="flex: 0 0 32%; background: white; border-radius: 15px; overflow: hidden; box-shadow: 0 10px 30px rgba(0,0,0,0.06); transition: 0.4s; border: 1px solid #f8f8f8;")
    img.p-img(src=(item.image || 'https://via.placeholder.com/400x500') style="width: 100%; height: 300px; object-fit: cover;")
    div(style="padding: 25px; text-align: center;")
      h3(style="font-family: 'Playfair Display', serif; font-size: 1.4rem; color: #1a1a1a; margin-bottom: 10px; line-height: 1.2; font-style: italic;")= item.name
      div(style="width: 40px; height: 2px; background: #d4af37; margin: 0 auto 15px auto;")
      
      p(style=`color: #555; font-weight: 600; font-size: 1.1rem; margin-bottom: 20px; font-family: 'Poppins', sans-serif;`)= (item.price ? item.price.toLocaleString('vi-VN') + ' VNĐ' : 'Liên hệ')
      
      //- Container cho 2 nút
      div(style="display: flex; gap: 10px; justify-content: center;")
        a(href=`/flower/${item._id}` style="padding: 10px 20px; border: 1px solid #333; color: #333; text-transform: uppercase; font-size: 0.7rem; letter-spacing: 1px; text-decoration: none; font-weight: 600; transition: 0.3s;") Xem chi tiết
        
        //- Nút Thêm vào giỏ
        form(action="/cart/add", method="POST" style="margin: 0;")
          input(type="hidden", name="flowerId", value=item._id.toString())
          button(type="submit" style="padding: 10px 15px; border: 1px solid #d4af37; background: #d4af37; color: white; cursor: pointer; transition: 0.3s; display: flex; align-items: center;")
            i.fas.fa-shopping-cart

  mixin sectionDivider
  div(style="text-align: center; margin: 60px 0; color: #d4af37; display: flex; align-items: center; justify-content: center; gap: 20px;")
    div(style="height: 1px; width: 100px; background: #d4af37;")
    div(style="font-size: 1.5rem;") ❦
    div(style="height: 1px; width: 100px; background: #d4af37;")

block content
  //- 1. HERO
  section(style="padding: 30px 8% 40px 8%; text-align: center; background: #fffcf5; border-bottom: 1px solid #d4af37;")
    div(style="font-size: 1.5rem; color: #d4af37; margin-bottom: 2px;") ❦
    h1(style="font-family: 'Playfair Display', serif; font-size: 2.6rem; color: #1a1a1a; margin-bottom: 2px; font-style: italic;") PNShop
    p(style="font-family: 'Poppins', sans-serif; font-size: 0.8rem; color: #888; margin-bottom: 20px; letter-spacing: 3px; text-transform: uppercase;") Nghệ thuật hoa tươi vượt thời gian
    
    form(action="/explore" method="GET" style="max-width: 500px; margin: 0 auto; display: flex; border: 2px solid #1a1a1a; background: white; box-shadow: 0 4px 15px rgba(0,0,0,0.05);")
      input(type="text" name="keyword" placeholder="Tìm kiếm bó hoa hoàn hảo cho bạn..." style="flex: 1; padding: 12px 20px; border: none; outline: none; font-family: 'Poppins'; font-size: 0.95rem; color: #333;")
      button(type="submit" style="padding: 12px 25px; background: #1a1a1a; border: none; cursor: pointer; color: white; transition: 0.3s;") 
        i.fas.fa-search

  //- 2. AUTO-SLIDER FEATURED
  section(style="padding: 60px 8%; overflow: hidden;")
    div(style="display: flex; align-items: center; justify-content: center; gap: 15px; margin-bottom: 40px;")
      div(style="color: #d4af37; font-size: 2rem; transform: translateY(-5px);") ❦
      h2(style="font-family: 'Playfair Display', serif; font-size: 2.5rem; color: #1a1a1a; font-style: italic; margin: 0;") Bộ sưu tập mới nhất
    
    #slider-container(style="position: relative; width: 100%; max-width: 1200px; margin: 0 auto;")
      button(onclick="moveSlide(-1)" style="position: absolute; left: -60px; top: 40%; background: none; border: 1px solid #d4af37; color: #d4af37; width: 45px; height: 45px; border-radius: 50%; cursor: pointer; transition: 0.3s;") ❮
      
      div(style="overflow: hidden; width: 100%;")
        #slider-track(style="display: flex; transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1); gap: 2%;")
          each page in [0, 1, 2]
            div(style="min-width: 100%; display: flex; justify-content: space-between;")
              each item in flowers.slice(page * 3, (page + 1) * 3)
                +productCard(item, "#d4af37")
    
      button(onclick="moveSlide(1)" style="position: absolute; right: -60px; top: 40%; background: none; border: 1px solid #d4af37; color: #d4af37; width: 45px; height: 45px; border-radius: 50%; cursor: pointer; transition: 0.3s;") ❯
      +sectionDivider

  //- 3. PRODUCT CATEGORIES
  mixin catSection(title, icon, color, items)
    section(style="padding: 40px 8%;")
      div(style="display: flex; align-items: center; justify-content: center; gap: 15px; margin-bottom: 40px;")
        i(class=`fas ${icon}` style=`color: ${color}; font-size: 1.5rem;`)
        h2(style="font-family: 'Playfair Display', serif; font-size: 2rem; color: #333; margin: 0;")= title
      div(style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px;")
        each item in items.slice(0, 3)
          +productCard(item, color)

  +catSection("Nghệ thuật Bonsai", "fa-leaf", "#2ecc71", ornamentalPlants)
  +sectionDivider
  +catSection("Hoa cưới sang trọng", "fa-heart", "#d63384", weddingFlowers)
  +sectionDivider
  +catSection("Quà tặng sinh nhật", "fa-birthday-cake", "#ff9f43", birthdayFlowers)
  +sectionDivider
  +catSection("Sự kiện & Hội nghị", "fa-microphone-alt", "#2c3e50", eventFlowers)
  +sectionDivider
  +catSection("Khai trương hồng phát", "fa-store", "#e74c3c", grandOpeningFlowers)
  +sectionDivider
  +catSection("Thiết kế theo chủ đề", "fa-magic", "#8e44ad", themedFlowers)
  +sectionDivider
  +catSection("Hoa theo mùa", "fa-cloud-sun", "#3498db", seasonalFlowers)
  +sectionDivider
  +catSection("Cây cảnh trang trí", "fa-couch", "#27ae60", decorPlants)
  +sectionDivider

  //- 4. Voucher
  section(style="padding: 100px 8%; text-align: center; background: #fdfdfd;")
    h3(style="font-family: 'Playfair Display', serif; font-size: 1.8rem; color: #1a1a1a; margin-bottom: 40px; font-style: italic;") Món quà đặc biệt dành cho bạn

    div(style="position: relative; max-width: 800px; margin: 0 auto; padding: 60px; background: #fff; background-image: radial-gradient(#d4af37 0.5px, transparent 0.5px); background-size: 20px 20px; border: 1px solid #d4af37; box-shadow: 0 20px 40px rgba(0,0,0,0.1), 0 0 0 10px #fffcf5, 0 0 0 11px #d4af37; display: flex; align-items: center; justify-content: space-between;")
      div(style="position: absolute; top: 20px; left: 20px; color: #d4af37; font-size: 2rem;") ❃
      div(style="text-align: left; flex: 1; padding-right: 40px; border-right: 1px dashed #d4af37;")
        h2(style="font-family: 'Playfair Display', serif; font-size: 2.2rem; color: #d4af37; margin-bottom: 20px;") Ưu đãi độc quyền
        p(style="font-family: 'Poppins', sans-serif; font-size: 0.95rem; color: #444; line-height: 1.8; margin-bottom: 20px;") 
          | Rất hân hạnh được chào đón bạn trở lại. 
          br
          | Hãy nhận món quà nhỏ này như một lời cảm ơn chân thành từ chúng tôi.
        div(style="font-family: 'Playfair Display', serif; font-weight: bold; color: #1a1a1a;") — PNShop

      div(style="flex: 0 0 350px; padding-left: 40px;")
        div(style="font-size: 0.7rem; color: #888; text-transform: uppercase; letter-spacing: 4px; margin-bottom: 10px;") Mã giảm giá
        div(style="position: relative; font-family: 'Playfair Display', serif; font-size: 3.5rem; font-weight: 900; color: #1a1a1a; letter-spacing: 8px; padding: 10px 0; margin-bottom: 20px;")
          | NEW2026
          div(style="position: absolute; bottom: 0; left: 15%; width: 70%; height: 2px; background: #d4af37;")
        
        button(onclick="navigator.clipboard.writeText('NEW2026'); alert('Đã sao chép mã!');" 
               onmouseover="this.style.background='#d4af37'; this.style.color='#fff';" 
               onmouseout="this.style.background='#1a1a1a'; this.style.color='#d4af37';"
               style="background: #1a1a1a; color: #d4af37; border: none; padding: 12px 35px; font-family: 'Playfair Display', serif; font-size: 0.9rem; letter-spacing: 3px; text-transform: uppercase; cursor: pointer; transition: all 0.3s;")
          | Nhận ưu đãi

  //- 5. CLOSING MESSAGE
  section(style="padding: 80px 8%; text-align: center; border-top: 1px solid #e0c9a6; margin-top: 50px; background: #fffcf5;")
    div(style="max-width: 700px; margin: 0 auto;")
      div(style="font-size: 1.5rem; color: #d4af37; margin-bottom: 20px;")
        i.fas.fa-leaf
      h3(style="font-family: 'Playfair Display', serif; font-size: 2rem; color: #1a1a1a; margin-bottom: 25px; font-style: italic;") Với lòng biết ơn sâu sắc
      p(style="font-family: 'Poppins', sans-serif; font-size: 1rem; color: #555; line-height: 2; letter-spacing: 0.8px; margin-bottom: 30px;") 
        | Cảm ơn bạn đã để PNShop trở thành một phần trong những khoảnh khắc đáng nhớ nhất của mình. 
        | Chúng tôi tin rằng hoa không chỉ là những cánh hoa; mà là ngôn ngữ thầm lặng của tình yêu, 
        | sự biết ơn và hy vọng. Hy vọng những đóa hoa từ vườn nhà chúng tôi sẽ mang lại 
        | sự ấm áp và duyên dáng cho cuộc sống của bạn.
      
      div(style="border-top: 1px solid #d4af37; width: 100px; margin: 0 auto 20px auto;")
      p(style="font-family: 'Playfair Display', serif; font-size: 1.2rem; color: #1a1a1a; font-style: italic;") 
        | Trân trọng,
        br
        | Đội ngũ PNShop
      div(style="margin-top: 20px; font-size: 1.2rem; color: #d4af37;")
        i.fas.fa-heart

  script.
    let currentPage = 0;
    const track = document.getElementById('slider-track');
    
    function moveSlide(direction) {
      currentPage = (currentPage + direction + 3) % 3;
      track.style.transform = `translateX(-${currentPage * 102}%)`;
      resetAutoSlide(); 
    }

    let autoSlide = setInterval(() => moveSlide(1), 5000);
    
    function resetAutoSlide() {
      clearInterval(autoSlide);
      autoSlide = setInterval(() => moveSlide(1), 5000);
    }