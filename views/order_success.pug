doctype html
html(lang="vi")
  head
    meta(charset="UTF-8")
    title Xác nhận đơn hàng - PNShop
    link(rel="stylesheet", href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css")
    link(href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;1,700&family=Quicksand:wght@300;400;600&display=swap", rel="stylesheet")
    style.
      body { font-family: 'Quicksand', sans-serif; background: #fafafa; padding: 40px 20px; display: flex; justify-content: center; }
      
      /* Bức thư nằm ngang */
      .letter-container { 
        background: white; width: 900px; padding: 60px; border: 1px solid #eee;
        box-shadow: 0 10px 40px rgba(0,0,0,0.05); position: relative;
      }
      
      .grid-letter { display: grid; grid-template-columns: 1fr 1fr; gap: 60px; }
      
      h1 { font-family: 'Playfair Display', serif; font-style: italic; color: #1a1a1a; font-size: 2rem; margin-bottom: 5px; }
      .order-id { font-size: 0.7rem; letter-spacing: 4px; text-transform: uppercase; color: #d4af37; margin-bottom: 40px; }
      
      h4 { font-family: 'Playfair Display', serif; font-size: 1rem; color: #1a1a1a; margin-bottom: 15px; border-bottom: 1px solid #d4af37; padding-bottom: 5px; }
      .detail-row { display: flex; justify-content: space-between; padding: 8px 0; font-size: 0.85rem; }
      
      /* Lời cảm ơn trang trọng */
      .closing-note { 
        margin-top: 50px; text-align: center; border-top: 1px solid #eee; padding-top: 30px;
        font-family: 'Playfair Display', serif; font-style: italic; color: #555;
      }

      .btn-group { display: flex; gap: 20px; margin-top: 30px; justify-content: center; }
      .btn { padding: 10px 30px; text-decoration: none; font-size: 0.7rem; text-transform: uppercase; letter-spacing: 2px; transition: 0.3s; border: 1px solid #1a1a1a; }
      .btn-primary { background: #1a1a1a; color: white; }
      .btn-outline { color: #d4af37; border-color: #d4af37; }

  body
    .letter-container
      div(style="text-align: center;")
        h1 Đơn hàng đã được xác nhận
        p.order-id Đơn hàng ##{order._id.toString().slice(-8).toUpperCase()}
      
      .grid-letter
        //- Cột trái: Thông tin cá nhân
        div
          h4 Thông tin gửi & nhận
          .detail-row #[span Người gửi:] #[strong #{order.senderName}]
          .detail-row #[span Người nhận:] #[strong #{order.customer.name}]
          .detail-row #[span Số điện thoại:] #[strong #{order.customer.phone}]
          div(style="margin-top: 20px;")
            h4 Địa chỉ giao hàng
            p(style="font-size: 0.85rem; color: #666; line-height: 1.6;")= order.customer.address
        
        //- Cột phải: Chi tiết đơn hàng
        div
          h4 Tổng quan đơn hàng
          each item in order.items
            .detail-row
              span #{item.name} (x#{item.qty})
              span= (item.price * item.qty).toLocaleString('vi-VN') + ' đ'
          .detail-row(style="border-top: 1px solid #eee; margin-top: 15px; padding-top: 15px; font-weight: 700; font-size: 1.1rem;")
            span Tổng cộng
            span= order.totalAmount.toLocaleString('vi-VN') + ' đ'

      //- Lời cảm ơn sang trọng
      .closing-note
        p "Thật là một vinh dự khi được góp mặt trong những khoảnh khắc đặc biệt của bạn. Chúng tôi đang cẩn thận chuẩn bị những đóa hoa tươi thắm nhất dành riêng cho bạn."
        p(style="margin-top: 10px; font-size: 1rem; color: #d4af37;") — Chân thành cảm ơn, PNShop —

      .btn-group
        a.btn.btn-outline(href="/explore") Tiếp tục mua sắm
        a.btn.btn-primary(href="/") Về trang chủ