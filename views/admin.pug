extends layout_admin

block content
  style.
    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700&family=Playfair+Display:ital,wght@0,700;1,700&display=swap');

    :root { --gold: #d4af37; --dark: #1a1a1a; }

    .admin-main { padding: 40px; background: #fcfcfc; min-height: 100vh; font-family: 'Montserrat', sans-serif; }
    h2, h3 { font-family: 'Playfair Display', serif; color: var(--dark); font-weight: 700; font-style: italic; }
    
    .admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; border-bottom: 2px solid var(--gold); padding-bottom: 20px; }
    .admin-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 30px; margin-bottom: 50px; }
    .stat-card { background: white; padding: 25px; border-radius: 15px; border-left: 4px solid var(--gold); box-shadow: 0 5px 15px rgba(0,0,0,0.03); }

    /* Buttons */
    .btn-add { background: var(--dark); color: white; padding: 10px 25px; border-radius: 8px; border: 1px solid var(--gold); font-weight: 700; cursor: pointer; transition: 0.3s; text-transform: uppercase; letter-spacing: 1px; font-size: 0.8rem; }
    .btn-add:hover { background: var(--gold); color: white; }
    .btn-toggle-cat { background: transparent; border: 1px solid #ddd; color: #888; padding: 5px 10px; border-radius: 5px; font-size: 0.7rem; cursor: pointer; margin-left: 15px; transition: 0.3s; }
    .btn-toggle-cat:hover { border-color: var(--gold); color: var(--gold); }

    /* Form & Table */
    .modal-form { background: white; padding: 30px; border-radius: 15px; border: 1px solid #eee; margin-bottom: 40px; }
    .form-group label { font-weight: 700; color: #888; font-size: 0.65rem; text-transform: uppercase; margin-bottom: 8px; display: block; }
    .form-group input, .form-group select { width: 100%; border: 1px solid #ddd; padding: 10px; border-radius: 8px; }
    .btn-submit { background: var(--gold); color: white; border: none; padding: 10px 25px; border-radius: 8px; cursor: pointer; font-weight: 700; }

    .admin-table { width: 100%; border-collapse: collapse; background: white; border-radius: 10px; overflow: hidden; margin-bottom: 50px; border: 1px solid #eee; }
    .admin-table thead { background: #f9f9f9; color: #444; text-transform: uppercase; font-size: 0.7rem; letter-spacing: 1px; }
    .admin-table th, .admin-table td { padding: 18px; text-align: left; border-bottom: 1px solid #f9f9f9; font-weight: 600; color: #444; }
    .admin-table img { width: 45px; height: 45px; border-radius: 8px; object-fit: cover; }
    .status-pill { padding: 4px 10px; border-radius: 6px; font-size: 0.7rem; font-weight: 800; border: 1px solid #eee; }

    .input-hint { font-size: 0.7rem; color: #888; font-style: italic; margin-top: 4px; display: block; }
    .form-group { margin-bottom: 15px; }
  main.admin-main
    header.admin-header
      h2(style="font-size: 1.8rem;") 📦 Quản lý kho hàng
      button.btn-add(onclick="toggleForm()") 
        i.fas.fa-plus-circle(style="margin-right: 8px;")
        | Thêm sản phẩm

    section.admin-stats
      .stat-card
        span(style="color: #888; font-size: 0.7rem; font-weight: 800; text-transform: uppercase;") 🌸 Tổng bộ sưu tập
        h2(style="margin: 5px 0 0; color: var(--dark); font-size: 2rem;") #{flowers ? flowers.length : 0}
      .stat-card
        span(style="color: #888; font-size: 0.7rem; font-weight: 800; text-transform: uppercase;") 📊 Tổng tồn kho
        - let totalStock = flowers ? flowers.reduce((sum, f) => sum + (f.stock || 0), 0) : 0
        h2(style="margin: 5px 0 0; color: var(--gold); font-size: 2rem;") #{totalStock}

    section#flower-form.modal-form(style="display:none")
      form(action="/admin/add", method="POST", enctype="multipart/form-data")
        h3(style="margin-bottom: 25px; font-size: 1.2rem;") ✨ Thêm sản phẩm hoa mới
        .form-row(style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;")
          .form-group: label 🏷️ Tên sản phẩm
            input(type="text", name="name", required)
          .form-group: label 📁 Danh mục
            select(name="category", required)
              each cat in ["Hoa cảnh", "Hoa đám cưới", "Hoa sinh nhật", "Hoa sự kiện", "Hoa khai trương", "Hoa chủ đề", "Hoa theo mùa", "Bonsai", "Cây cảnh trang trí"]
                option(value=cat)= cat
        .form-row(style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 20px;")
        .form-group
          label 💰 Giá vốn
          input(type="number", name="cost_price", min="1", step="1", required, oninput="validateInteger(this)")
          small.input-hint Chỉ nhập số nguyên dương (không bao gồm ký tự đặc biệt)

        .form-group
          label 🏷️ Giá bán
          input(type="number", name="price", min="1", step="1", required, oninput="validateInteger(this)")
          small.input-hint Chỉ nhập số nguyên dương (không bao gồm ký tự đặc biệt)

        .form-group
          label 📦 Tồn kho
          input(type="number", name="stock", min="0", step="1", required, oninput="validateInteger(this)")
          small.input-hint Chỉ nhập số nguyên dương (có thể là 0)
        .form-group: label 🖼️ Hình ảnh sản phẩm
          input(type="file", name="image", accept="image/*", required)
        div(style="margin-top: 25px;")
          button.btn-submit(type="submit") Lưu sản phẩm
          button(type="button", onclick="toggleForm()" style="background: none; border: none; margin-left: 20px; cursor: pointer; color: #888; font-weight: 600;") Hủy bỏ

    - const allCategories = ["Hoa cảnh", "Hoa đám cưới", "Hoa sinh nhật", "Hoa sự kiện", "Hoa khai trương", "Hoa chủ đề", "Hoa theo mùa", "Bonsai", "Cây cảnh trang trí"]
    each cat, index in allCategories
      - const catId = 'cat-' + index
      - const productsInCategory = flowers ? flowers.filter(f => f.category === cat) : []
      if productsInCategory.length > 0
        section(style="margin-bottom: 40px;")
          div(style="display: flex; align-items: center; margin-bottom: 20px;")
            h3(style="color: var(--gold); margin: 0; font-size: 1.3rem;") 🌿 #{cat}
            button.btn-toggle-cat(onclick=`toggleCategory('${catId}')`) Đóng/Mở
          
          div(id=catId class="category-container")
            table.admin-table
              thead
                tr
                  th Ảnh
                  th Tên sản phẩm
                  th Giá bán
                  th Trạng thái
                  th Thao tác
              tbody
                each flower in productsInCategory
                  tr
                    td: img(src=flower.image)
                    td(style="font-weight: 700;")= flower.name
                    td(style="color: var(--gold); font-weight: 800;") #{(flower.price || 0).toLocaleString('vi-VN')} đ
                    td
                      if !flower.stock || flower.stock <= 0
                        span.status-pill(style="background:#1a1a1a; color:#fff;") Hết hàng
                      else
                        span.status-pill(style="background:#fdf5e6; color:var(--gold); border: 1px solid var(--gold);") #{flower.stock} sản phẩm
                    td
                      a(href=`/admin/edit/${flower._id}` style="color: #666; margin-right: 15px;")
                        i.fas.fa-edit
                      a(href=`/admin/delete/${flower._id}` onclick="return confirm('Bạn có chắc chắn muốn xóa?')" style="color: #666;")
                        i.fas.fa-trash-alt

  script.
    document.addEventListener("DOMContentLoaded", () => {
      const allCats = !{JSON.stringify(allCategories.map((c, i) => 'cat-' + i))};
      allCats.forEach(catId => {
        const isHidden = localStorage.getItem(catId) === 'true';
        const container = document.getElementById(catId);
        if (container) {
          container.style.display = isHidden ? 'none' : 'block';
        }
      });
    });

    function toggleForm() {
      const form = document.getElementById('flower-form');
      form.style.display = (form.style.display === 'none' || form.style.display === '') ? 'block' : 'none';
      if(form.style.display === 'block') form.scrollIntoView({ behavior: 'smooth' });
    }

    function toggleCategory(catId) {
      const container = document.getElementById(catId);
      const isCurrentlyHidden = container.style.display === 'none';
      container.style.display = isCurrentlyHidden ? 'block' : 'none';
      localStorage.setItem(catId, !isCurrentlyHidden);
    }
    function validateInteger(input) {
      // Loại bỏ tất cả trừ số, ngăn chặn số 0 ở đầu (trừ khi giá trị là chính số 0)
      input.value = input.value.replace(/[^0-9]/g, '');
      if (input.value.length > 1 && input.value.startsWith('0')) {
        input.value = input.value.replace(/^0+/, '');
      }
    }